---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Build. Break. Learn.</p>
				<h1>
					Bold experiments from a curious engineer.
				</h1>
				<p class="subtitle">
					My space for building things, breaking assumptions, and learning in
					public.
				</p>
			</section>
			<div class="container">
				<section class="why">
					<h2>Why this site exists</h2>
					<p>
						It's 2026 and we have more platforms than time, but none of them feel truly ours.
						This space is the antidote. No algorithms deciding who sees what, no engagement hacks,
						no performative thought leadership. Just a quiet corner of the web where I can drop
						in-progress ideas, half-formed diagrams, and the occasional rant about misused queues.
					</p>
					<p>
						I write here to remember what I've learned, to leave breadcrumbs for future-me, and
						to give anyone walking a similar path something real to grab onto. Learning in public
						is messy, but it beats waiting until something is "perfect" enough for Medium or
						LinkedIn. This site is mine, which means the experiments, the mistakes, and the wins
						get to live in one place.
					</p>
				</section>

				<section class="what">
					<h2>What you'll find here</h2>
					<div class="cards">
						<a class="card" href="/blog">
							<h3>Blog</h3>
							<p>
								Long-form posts on the mechanics of engineering, the realities of day-to-day 
								techincal and non technical challenges I face and learn especially adopting AI,
								and those small lessons that only show up after a production incident.
							</p>
						</a>
						<a class="card" href="/projects">
							<h3>Projects</h3>
							<p>
								A rotating shelf of things I'm building—from polished portfolio work to
								internal tools that scratched a very specific "itch".
							</p>
						</a>
						<a class="card" href="/experiments">
							<h3>Experiments</h3>
							<p>
								Rough sketches, unusual stacks, and the frameworks I'm poking at before deciding
								whether they're worth a rollout.
							</p>
						</a>
					</div>
				</section>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		color: rgb(var(--black));
		background: #fff;
	}

	.hero {
		background: linear-gradient(135deg, var(--gray-gradient, #f5f7ff), rgba(var(--gray-light), 0.9)),
			rgba(var(--gray-light), 0.8);
		padding: 5rem 1.5rem 4rem;
		text-align: center;
		color: rgb(var(--gray-dark));
	}

	.hero h1 {
		font-size: 3.052em;
		max-width: 960px;
		margin: 0 auto 1rem;
		color: rgb(var(--black));
	}

	.hero .eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.85rem;
		color: var(--accent-dark);
		margin-bottom: 1rem;
	}

	.hero .subtitle {
		font-size: 1.25rem;
		max-width: 720px;
		margin: 0 auto;
		color: rgb(var(--gray));
	}

	.container {
		max-width: 720px;
		margin: 0 auto;
		padding: 3rem 1.5rem 4rem;
	}

	section + section {
		margin-top: 3rem;
	}

	h2 {
		font-size: 2.441em;
		margin-bottom: 1rem;
	}

	h3 {
		font-size: 1.953em;
		margin-bottom: 0.75rem;
	}

	p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: rgb(var(--gray-dark));
		margin-bottom: 1.25rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.card {
		display: block;
		background: #fff;
		border: 1px solid rgba(var(--gray-light), 0.8);
		border-radius: 12px;
		padding: 1.5rem;
		text-decoration: none;
		color: inherit;
		box-shadow: 0 10px 25px rgba(15, 18, 25, 0.05);
		transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
	}

	.card:hover,
	.card:focus-visible {
		transform: translateY(-4px);
		border-color: var(--accent);
		box-shadow: 0 20px 40px rgba(35, 55, 255, 0.1);
	}

	.card p {
		margin: 0;
	}

	@media (max-width: 600px) {
		.hero {
			padding: 4rem 1rem 3rem;
			text-align: left;
		}

		.hero h1 {
			font-size: 2.488em;
		}

		.hero .subtitle {
			font-size: 1.05rem;
		}
	}
</style>
