---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<p class="eyebrow">Build. Break. Learn.</p>
				<h1>
					Bold experiments from a curious engineer.
				</h1>
				<p class="subtitle">
					A quiet corner of the web where I drop in-progress ideas, share what I'm learning,
					and leave breadcrumbs for anyone walking a similar path.
				</p>
			</section>
			<div class="container">
				<div class="cards">
					<a class="card" href="/blog">
						<h3>Blog</h3>
						<p>
							Long-form posts on the mechanics of engineering, the realities of day-to-day
							technical and non-technical challenges I face and learn especially adopting AI,
							and those small lessons that only show up after a production incident.
						</p>
					</a>
					<a class="card" href="/projects">
						<h3>Projects</h3>
						<p>
							A rotating shelf of things I'm building—from polished portfolio work to
							internal tools that scratched a very specific "itch".
						</p>
					</a>
					<a class="card" href="/experiments">
						<h3>Experiments</h3>
						<p>
							Rough sketches, unusual stacks, and the frameworks I'm poking at before deciding
							whether they're worth a rollout.
						</p>
					</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		color: rgb(var(--black));
		background: #fff;
	}

	.hero {
		background: linear-gradient(135deg, var(--gray-gradient, #f5f7ff), rgba(var(--gray-light), 0.9)),
			rgba(var(--gray-light), 0.8);
		padding: 5rem 1.5rem 4rem;
		text-align: center;
		color: rgb(var(--gray-dark));
	}

	.hero h1 {
		font-size: 3.052em;
		max-width: 960px;
		margin: 0 auto 1rem;
		color: rgb(var(--black));
	}

	.hero .eyebrow {
		text-transform: uppercase;
		letter-spacing: 0.2em;
		font-size: 0.85rem;
		color: var(--accent-dark);
		margin-bottom: 1rem;
	}

	.hero .subtitle {
		font-size: 1.25rem;
		max-width: 720px;
		margin: 0 auto;
		color: rgb(var(--gray));
	}

	.container {
		max-width: 720px;
		margin: 0 auto;
		padding: 2rem 1.5rem 4rem;
	}

	h3 {
		font-size: 1.953em;
		margin-bottom: 0.75rem;
	}

	p {
		font-size: 1.1rem;
		line-height: 1.8;
		color: rgb(var(--gray-dark));
		margin-bottom: 1.25rem;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
		gap: 1rem;
	}

	.card {
		display: block;
		background: #fff;
		border: 1px solid rgba(var(--gray-light), 0.8);
		border-radius: 12px;
		padding: 1.5rem;
		text-decoration: none;
		color: inherit;
		box-shadow: 0 10px 25px rgba(15, 18, 25, 0.05);
		transition: transform 150ms ease, box-shadow 150ms ease, border-color 150ms ease;
	}

	.card:hover,
	.card:focus-visible {
		transform: translateY(-4px);
		border-color: var(--accent);
		box-shadow: 0 20px 40px rgba(35, 55, 255, 0.1);
	}

	.card p {
		margin: 0;
	}

	@media (max-width: 600px) {
		.hero {
			padding: 4rem 1rem 3rem;
			text-align: left;
		}

		.hero h1 {
			font-size: 2.488em;
		}

		.hero .subtitle {
			font-size: 1.05rem;
		}
	}
</style>
