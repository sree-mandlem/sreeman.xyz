---
interface Props {
	date?: Date;
}

const { date } = Astro.props;
const display = date
	? date.toLocaleDateString('en-us', {
			year: 'numeric',
			month: 'short',
			day: 'numeric',
	  })
	: 'Date TBA';
const dateTime = date ? date.toISOString() : undefined;
---

<time datetime={dateTime}>{display}</time>
